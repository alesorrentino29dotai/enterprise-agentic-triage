# Copy to `.env` and fill in. All values are optional — the agent degrades
# gracefully (heuristic triage + extractive answers) when ANTHROPIC_API_KEY is
# absent, so the workflow is fully demonstrable without credentials.

# ── LLM backend ──────────────────────────────────────────────────────────────
# auto (default): local vLLM if reachable → Claude if key set → heuristics.
# Force one with: vllm | anthropic | heuristic
# LLM_BACKEND=auto

# Anthropic (Claude Opus 4.8). When set, triage + answers run on the cloud model.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# ── Local GPU backend (vLLM on your RTX 5070) ────────────────────────────────
# Start it with ./serve_vllm.sh, then set LLM_BACKEND=vllm (or leave auto).
# VLLM_BASE_URL=http://127.0.0.1:8001/v1
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
# VLLM_API_KEY=EMPTY

# Local models for the Advanced RAG pipeline (downloaded on first run)
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Where the mock REST API is reachable for the Action Node
# MOCK_API_BASE=http://127.0.0.1:8000

# Non-interactive HITL override for the webhook / CI: approve | deny
# TRIAGE_AUTO_APPROVE=
